# Server Configuration
PORT=3000
HOST=127.0.0.1

# Database Configuration
DATABASE_URL="file:./dev.db"

# AI/LLM Configuration
# 支持的 provider: deepseek, siliconflow, openai, anthropic, grok, kimi, minimax, glm, qwen, gemini, ollama, mimo
DEFAULT_LLM_PROVIDER=mimo

# MiMo API Configuration (小米大模型)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomi.com/v1
MIMO_MODEL=mimo-v2.5-pro

# OpenAI API Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5

# Anthropic API Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# DeepSeek API Configuration
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen API Configuration (通义千问)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# GLM API Configuration (智谱)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.5-air

# Kimi API Configuration (月之暗面)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k

# Gemini API Configuration
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# Application Configuration
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Feature Flags
ENABLE_WORLD_WIZARD=true
ENABLE_STYLING=true
ENABLE_RAG=true

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=info
